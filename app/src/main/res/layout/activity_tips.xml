<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌿 Safe Beekeeping Tips"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginBottom="30dp"/>

        <!-- TIP 1 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Spray pesticides in evening"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:padding="14dp"
            android:layout_marginBottom="18dp"/>

        <!-- TIP 2 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Avoid spraying near hives"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:padding="14dp"
            android:layout_marginBottom="18dp"/>

        <!-- TIP 3 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Inform beekeeper before spraying"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:padding="14dp"
            android:layout_marginBottom="18dp"/>

        <!-- TIP 4 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Use organic pesticides"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:padding="14dp"
            android:layout_marginBottom="18dp"/>

        <!-- TIP 5 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Keep bees away from chemicals"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:padding="14dp"
            android:layout_marginBottom="18dp"/>

    </LinearLayout>

</ScrollView>