<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌾 SPRAYING TODAY"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="20dp"/>

        <!-- CROP -->
        <TextView
            android:id="@+id/tvCrop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🌱 Crop: Tomato"
            android:textSize="20sp"
            android:textStyle="bold"
            android:padding="10dp"/>

        <!-- PESTICIDE -->
        <TextView
            android:id="@+id/tvPesticide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🧪 Suggested Pesticide: Neem Spray"
            android:textSize="18sp"
            android:padding="10dp"/>

        <!-- TIME -->
        <TextView
            android:id="@+id/tvTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏰ Best Time: 6:00 AM - 8:00 AM"
            android:textSize="18sp"
            android:padding="10dp"/>

        <!-- WEATHER -->
        <TextView
            android:id="@+id/tvWeather"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="☁️ Weather: Good for Spraying"
            android:textSize="18sp"
            android:padding="10dp"/>

        <!-- RESULT -->
        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#4CAF50"
            android:layout_marginTop="20dp"/>

        <!-- BUTTON -->
        <Button
            android:id="@+id/btnCheck"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ CHECK SPRAYING"
            android:layout_marginTop="20dp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

</ScrollView>